{
  "version": 2,
  "public": true,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
